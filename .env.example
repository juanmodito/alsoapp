# Dito Orders Portal — Environment Configuration Example
# Copy this file to .env.local and populate authentic runtime credentials

# Application Server Port & URLs
PORT=3000
APP_URL=https://your-cloud-run-app-uc.a.run.app

# Google OAuth 2.0 Client Credentials (Production Workspace Sign-In)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Google Reseller API & Gmail API Domain Delegation Credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=dito-orders-portal-sa@your-project-id.iam.gserviceaccount.com
GOOGLE_ADMIN_SUBJECT_EMAIL=admin@yourdomain.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Sheets Integration (Catalog & Order Prorated Audit Log)
GOOGLE_SHEETS_SPREADSHEET_ID=1mTUa44Wun2YHIbCT7D7VYa1NWcfYuddLpJgBSHHjGTA
GOOGLE_SHEETS_PRORATED_LICENSES_ID=1GhqvuG-ySIY-aDETk0gDGWxOF9GZqFPQTi2E6IUClRQ

# Order Email Notification Recipients (Comma-separated)
NOTIFICATION_EMAIL_TO="ar@ditoweb.com,ops@ditoweb.com"
